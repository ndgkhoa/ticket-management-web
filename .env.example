# Base URL of the API. Leave empty to use the same origin (relative paths).
# Must be a valid absolute URL when set, or the app fails fast at boot.
VITE_BASE_API_URL=

# Where the app gets its data: `live` | `msw`
#   live -> talks to VITE_BASE_API_URL
#   msw  -> starts the Service Worker and answers from src/mocks/handlers.ts,
#           which lets the app run with no backend at all
# Defaults to `live` when unset.
VITE_API_MODE=live
