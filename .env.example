# Where the app gets its data: `supabase` | `msw`
#   supabase -> talks to the real project (VITE_SUPABASE_* below)
#   msw      -> starts the Service Worker and answers from the mock handlers,
#               which lets the app and tests run with no backend at all
# Defaults to `supabase` when unset.
VITE_API_MODE=supabase

# Supabase project URL and anon (publishable) key.
# Required when VITE_API_MODE=supabase; unused for msw.
#
# The anon key is PUBLIC by design — it identifies the project, not the user, and
# every row it reaches is gated by row level security. It is meant to ship in the
# client bundle. NEVER put the service_role key in a VITE_-prefixed var: it bypasses
# RLS and would be readable by anyone who opens the bundle.
#
# Local dev (`supabase start` / `supabase status` print these): URL is
# http://127.0.0.1:54321 and the anon key is the fixed local demo key.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# Cloudflare Turnstile site key (public) for the login/sign-up captcha. Leave UNSET to
# disable the captcha (tests, MSW demo, fresh checkout). The value below is Cloudflare's
# always-pass TEST key — swap for a real one in production. Must be paired with
# TURNSTILE_SECRET below and [auth.captcha] in supabase/config.toml.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# --- Supabase CLI vars (NOT VITE_-prefixed, so the browser never sees them) ---
# Read by `supabase start` to substitute env(...) in supabase/config.toml.

# Google OAuth — REQUIRED: the provider is enabled in supabase/config.toml, so
# `supabase start` fails fast until these are set. Create a Web OAuth client in Google
# Cloud Console, paste the id + secret here, then `bun run db:stop && bun run db:start`.
# The Google client's Authorized redirect URI must be:
#   http://127.0.0.1:54321/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Turnstile secret key — REQUIRED because [auth.captcha] is enabled in config.toml.
# The value below is Cloudflare's always-pass TEST secret; use a real one in production.
TURNSTILE_SECRET=1x0000000000000000000000000000000AA
