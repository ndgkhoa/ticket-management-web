# Where the app gets its data: `supabase` | `msw`
#   supabase -> talks to the real project (VITE_SUPABASE_* below)
#   msw      -> starts the Service Worker and answers from the mock handlers,
#               which lets the app and tests run with no backend at all
# Defaults to `supabase` when unset.
VITE_API_MODE=supabase

# Supabase project URL and anon (publishable) key.
# Required when VITE_API_MODE=supabase; unused for msw.
#
# The anon key is PUBLIC by design — it identifies the project, not the user, and
# every row it reaches is gated by row level security. It is meant to ship in the
# client bundle. NEVER put the service_role key in a VITE_-prefixed var: it bypasses
# RLS and would be readable by anyone who opens the bundle.
#
# Local dev (`supabase start` / `supabase status` print these): URL is
# http://127.0.0.1:54321 and the anon key is the fixed local demo key.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
