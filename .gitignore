.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Lock files — bun.lock IS committed on purpose.
# This is an application, not a library: the lockfile is what makes CI and a
# teammate's install reproduce the exact tree that was tested. Only the lockfiles
# of package managers this project doesn't use are ignored, so a stray `npm i`
# can't smuggle a second source of truth into the repo.
package-lock.json
yarn.lock
pnpm-lock.yaml

# Environment files
.env
.env.*.local
